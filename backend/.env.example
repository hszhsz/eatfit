# Supabase (required for persistent profiles)
SUPABASE_URL=https://vdllydxlrhuvulkgtzhe.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# LLM Coach (optional — falls back to local heuristic if not set)
# Default provider: Volcengine Ark + minimax-m3
# Override BASE_URL / MODEL only when using an alternate provider such as Moonshot.
EATFIT_LLM_API_KEY=
EATFIT_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
EATFIT_LLM_MODEL=minimax-m3
