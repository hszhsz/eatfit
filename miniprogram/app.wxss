/**app.wxss**/
page {
  background: #0a0a0a;
  color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  min-height: 100vh;
}

/* ===== 全局变量 ===== */
.theme-orange { color: #ff8a3d; }
.theme-green { color: #22c55e; }
.theme-blue { color: #3b82f6; }
.bg-card {
  background: linear-gradient(135deg, #1a1a1a 0%, #141414 100%);
  border: 1rpx solid #1f1f1f;
  border-radius: 32rpx;
}
.bg-card-flat {
  background: #141414;
  border: 1rpx solid #1f1f1f;
  border-radius: 28rpx;
}

/* ===== 通用工具类 ===== */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.items-center { align-items: center; }
.gap-sm { gap: 8rpx; }
.gap-md { gap: 16rpx; }
.gap-lg { gap: 24rpx; }

.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 40rpx; }
.text-2xl { font-size: 48rpx; }

.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }

.text-gray { color: #6b7280; }
.text-gray-light { color: #9ca3af; }
.text-white { color: #f5f5f5; }
.text-orange { color: #ff8a3d; }

.mt-sm { margin-top: 8rpx; }
.mt-md { margin-top: 16rpx; }
.mt-lg { margin-top: 24rpx; }
.mb-sm { margin-bottom: 8rpx; }
.mb-md { margin-bottom: 16rpx; }
.mb-lg { margin-bottom: 24rpx; }
.p-md { padding: 16rpx; }
.p-lg { padding: 24rpx; }
.px-md { padding-left: 16rpx; padding-right: 16rpx; }
.px-lg { padding-left: 24rpx; padding-right: 24rpx; }
.py-md { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-lg { padding-top: 24rpx; padding-bottom: 24rpx; }

/* ===== 渐变文字 ===== */
.gradient-text {
  background: linear-gradient(135deg, #ff8a3d, #22c55e);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

/* ===== 进度条 ===== */
.progress-track {
  height: 8rpx;
  background: #1f1f1f;
  border-radius: 4rpx;
  overflow: hidden;
}
.progress-fill-orange {
  height: 100%;
  background: linear-gradient(90deg, #ff8a3d, #22c55e);
  border-radius: 4rpx;
}

/* ===== 标签 ===== */
.tag {
  font-size: 18rpx;
  padding: 4rpx 16rpx;
  background: #1f1f1f;
  color: #9ca3af;
  border-radius: 100rpx;
  display: inline-block;
}

/* ===== 按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, #ff8a3d, #ff5a1f);
  color: #fff;
  border: none;
  border-radius: 100rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}
.btn-primary::after { border: none; }

.btn-secondary {
  background: #1f1f1f;
  color: #f5f5f5;
  border: 1rpx solid #2a2a2a;
  border-radius: 100rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  text-align: center;
}
.btn-secondary::after { border: none; }

/* ===== loading ===== */
.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff8a3d;
  animation: pulse 1.4s infinite ease-in-out;
}
@keyframes pulse {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}
