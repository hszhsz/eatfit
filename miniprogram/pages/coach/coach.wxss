/* pages/coach/coach.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx;
}
.text-6xl { font-size: 96rpx; }

/* ===== 焦点选择 ===== */
.focus-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.focus-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #141414;
  border: 1rpx solid #1f1f1f;
  gap: 8rpx;
}
.focus-chip.active {
  background: rgba(255, 138, 61, 0.12);
  border-color: #ff8a3d;
}
.focus-emoji {
  font-size: 48rpx;
}
.focus-label {
  font-size: 26rpx;
  color: #9ca3af;
}
.focus-chip.active .focus-label {
  color: #ff8a3d;
  font-weight: 600;
}

/* ===== 消息输入 ===== */
.message-input {
  background: #141414;
  border: 1rpx solid #1f1f1f;
  border-radius: 20rpx;
  padding: 24rpx;
  color: #f5f5f5;
  font-size: 28rpx;
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
}

/* ===== Loading ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

/* ===== 建议卡片 ===== */
.advice-section {
  padding-top: 8rpx;
}

.advice-hero {
  position: relative;
}

/* 评分圆环 */
.score-ring {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.score-ring.good { background: rgba(34, 197, 94, 0.15); border: 2rpx solid #22c55e; }
.score-ring.ok { background: rgba(245, 158, 11, 0.15); border: 2rpx solid #f59e0b; }
.score-ring.bad { background: rgba(239, 68, 68, 0.15); border: 2rpx solid #ef4444; }
.score-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #f5f5f5;
}

.advice-card {
  display: flex;
  flex-direction: column;
}
.advice-item {
  padding: 8rpx 0;
}

.disclaimer {
  padding: 16rpx;
  text-align: center;
}
