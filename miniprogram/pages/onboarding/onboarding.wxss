/* pages/onboarding/onboarding.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ===== 步骤指示器 ===== */
.steps {
  position: relative;
}
.step-item {
  flex-shrink: 0;
  z-index: 1;
}
.step-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #1f1f1f;
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}
.step-dot.active {
  background: linear-gradient(135deg, #ff8a3d, #ff5a1f);
  color: #fff;
}
.step-line {
  flex: 1;
  height: 4rpx;
  background: #1f1f1f;
  margin-top: 26rpx;
  margin-left: 8rpx;
  margin-right: 8rpx;
}
.step-line.active {
  background: linear-gradient(90deg, #ff8a3d, #22c55e);
}

/* ===== 表单 ===== */
.form-section {
  padding-top: 24rpx;
}
.form-group {
  display: flex;
  flex-direction: column;
}
.form-input {
  background: #141414;
  border: 1rpx solid #1f1f1f;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  color: #f5f5f5;
  font-size: 30rpx;
}
.form-picker {
  background: #141414;
  border: 1rpx solid #1f1f1f;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
}
.radio-group {
  display: flex;
  gap: 24rpx;
}
.radio-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 30rpx;
}

/* ===== 选项 chips ===== */
.option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.option-chip {
  padding: 16rpx 40rpx;
  border-radius: 100rpx;
  background: #141414;
  border: 1rpx solid #1f1f1f;
  color: #9ca3af;
  font-size: 28rpx;
  text-align: center;
}
.option-chip.active {
  background: linear-gradient(135deg, #ff8a3d, #ff5a1f);
  border-color: transparent;
  color: #fff;
  font-weight: 600;
}

.chip {
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
  background: #141414;
  border: 1rpx solid #1f1f1f;
  color: #9ca3af;
  font-size: 26rpx;
}
.chip.active {
  background: rgba(255, 138, 61, 0.15);
  border-color: #ff8a3d;
  color: #ff8a3d;
}
