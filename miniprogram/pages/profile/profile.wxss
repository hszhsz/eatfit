/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  padding-top: 24rpx;
  padding-bottom: 60rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx;
}
.text-6xl { font-size: 96rpx; }

/* ===== 用户卡片 ===== */
.user-card {
  display: flex;
  align-items: center;
}
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff8a3d, #ff5a1f);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

/* ===== 数据行 ===== */
.data-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #1a1a1a;
}
.data-row:last-child {
  border-bottom: none;
}

/* ===== 目标网格 ===== */
.target-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}
.target-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.target-cell text {
  display: block;
}

.macro-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}
.macro-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.macro-cell text {
  display: block;
}

/* ===== 操作 ===== */
.actions {
  display: flex;
  flex-direction: column;
}
.btn-danger {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  border-radius: 100rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  text-align: center;
}
.btn-danger::after { border: none; }

/* ===== 关于 ===== */
.about {
  display: flex;
  flex-direction: column;
  align-items: center;
}
