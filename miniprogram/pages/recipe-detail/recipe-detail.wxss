/* pages/recipe-detail/recipe-detail.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

/* ===== Hero ===== */
.hero {
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.hero.breakfast { background: linear-gradient(135deg, rgba(245,158,11,0.15), transparent); }
.hero.lunch { background: linear-gradient(135deg, rgba(34,197,94,0.15), transparent); }
.hero.dinner { background: linear-gradient(135deg, rgba(59,130,246,0.15), transparent); }
.hero.snack { background: linear-gradient(135deg, rgba(168,85,247,0.15), transparent); }
.hero-emoji {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}
.hero-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ===== 营养网格 ===== */
.nutrition-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 16rpx;
}
.nutri-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.nutri-cell text {
  display: block;
}

/* ===== 食材 ===== */
.ingredient-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #1a1a1a;
}
.ingredient-row:last-child {
  border-bottom: none;
}

/* ===== 步骤 ===== */
.step-row {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #1a1a1a;
}
.step-row:last-child {
  border-bottom: none;
}
.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff8a3d, #ff5a1f);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ===== 过敏原 ===== */
.allergen-alert {
  padding: 20rpx 28rpx;
  background: rgba(239, 68, 68, 0.1);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  border-radius: 20rpx;
  color: #f87171;
}
