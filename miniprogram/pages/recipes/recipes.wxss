/* pages/recipes/recipes.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.filter-bar {
  padding: 16rpx 24rpx;
  white-space: nowrap;
}
.filter-list {
  display: inline-flex;
}
.filter-chip {
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
  background: #141414;
  border: 1rpx solid #1f1f1f;
  color: #9ca3af;
  font-size: 26rpx;
  flex-shrink: 0;
}
.filter-chip.active {
  background: linear-gradient(135deg, #ff8a3d, #ff5a1f);
  border-color: transparent;
  color: #fff;
  font-weight: 600;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.text-6xl { font-size: 96rpx; }

.recipe-list {
  padding-top: 8rpx;
}
.recipe-card {
  align-items: center;
}
.recipe-emoji-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.recipe-emoji-box.breakfast { background: linear-gradient(135deg, #f59e0b, #d97706); }
.recipe-emoji-box.lunch { background: linear-gradient(135deg, #22c55e, #15803d); }
.recipe-emoji-box.dinner { background: linear-gradient(135deg, #3b82f6, #1e40af); }
.recipe-emoji-box.snack { background: linear-gradient(135deg, #a855f7, #7e22ce); }
.recipe-emoji { font-size: 48rpx; }
